{
  "name": "@streetspeak-ai/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "streetspeak": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@streetspeak-ai/brokers": "workspace:*",
    "@streetspeak-ai/core": "workspace:*",
    "@streetspeak-ai/execution": "workspace:*"
  }
}
